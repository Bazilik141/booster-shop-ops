# AUTO-002: env config for auto_review.py
# Copy this file to repo-root .env.review (preferred) or scripts/.env and fill in real values.
# NEVER commit either local secrets file.

# Claude API key — from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Notion Personal Access Token (preferred) — from notion.so/profile/integrations
# It acts with the owner's Roadmap permissions; never commit the real value.
NOTION_TOKEN=ntn_...

# AUTO-003: Google Search Console (for scripts/seo_monitor.py)
GSC_CLIENT_ID=...
GSC_CLIENT_SECRET=...
GSC_REFRESH_TOKEN=...
GSC_SITE_URL=https://boosterok.com.ua/
